# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# uv — do NOT commit uv.lock. Streamlit Community Cloud picks uv.lock over
# requirements.txt (higher precedence) and installs main deps only, missing the
# ml/app extras (torch etc.), which breaks the deployed app.
uv.lock

# Large generated artifacts — the training library, THOR run outputs, checkpoints, plots.
# These are regenerated from code + config; never commit them.
runs/
# ad-hoc THOR scratch dirs (e.g. runs_thor_sens from scripts/thor_sensitivity.py)
runs_*/
library/
*.h5
*.hdf5
*.npz
*.pt
*.ckpt
checkpoints/
*.png
*.pdf

# ...EXCEPT the trained checkpoints, which ARE published so the deployed
# Streamlit app can load models (the ~155 MB library stays out — too big for git).
!checkpoints/
!checkpoints/*.pt

# Small held-out "deploy packs" ARE published (they stand in for the big library on
# Streamlit Cloud — see scripts/make_deploy_packs.py + core.load_holdout fallback).
!deploy/
!deploy/*.npz

# Validation plates ARE published: they drive the home "calibrated" badge (home._validated)
# and the whole Method tab (app/views/how.py reads validation/<stem>/*.png).
!validation/
!validation/**/*.png

# Old deep-field UI media (fly-around movie + poster) — unused by the current
# console app (grep-verified: no references); kept local, not published.
app/static/

# Local dev noise / run logs — not for the public repo
logs/
sbi-logs/
scratch_repro.py

# OS
.DS_Store
